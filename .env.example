# Appwrite client environment variables
# Add these in your Appwrite Hosting/Deploy settings or your local .env file.

VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=your_project_id
VITE_APPWRITE_DATABASE_ID=your_database_id
VITE_APPWRITE_USER_COLLECTION_ID=your_users_collection_id
VITE_APPWRITE_MESSAGE_COLLECTION_ID=your_messages_collection_id
VITE_APPWRITE_STORAGE_ID=your_storage_bucket_id
